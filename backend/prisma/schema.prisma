datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  password_hash  String
  role           String    @default("Reader") // "Admin", "Editor", "Reader"
  is_validated   Boolean   @default(false)
  created_at     DateTime  @default(now())
  
  // Relations
  members_created Member[]
}

model Member {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  gender       String    // "M", "F", "Other"
  birthDate    DateTime?
  deathDate    DateTime?
  photoUrl     String?
  professions  String?
  contact      String?
  extraInfo    String?
  isPrivate    Boolean   @default(false)
  
  authorId     Int?
  author       User?     @relation(fields: [authorId], references: [id])
  
  // Relations (parent-child)
  parentsRelation Relation[] @relation("ChildRelations")
  childrenRelation Relation[] @relation("ParentRelations")
  
  // Relations (couple)
  partners1    Couple[]  @relation("Partner1")
  partners2    Couple[]  @relation("Partner2")
}

model Relation {
  id        Int      @id @default(autoincrement())
  parentId  Int
  childId   Int
  type      String   // "Biological", "Adopted"
  
  parent    Member   @relation("ParentRelations", fields: [parentId], references: [id])
  child     Member   @relation("ChildRelations", fields: [childId], references: [id])

  @@unique([parentId, childId])
}

model Couple {
  id          Int       @id @default(autoincrement())
  partner1Id  Int
  partner2Id  Int
  startDate   DateTime?
  endDate     DateTime? // if separated
  
  partner1    Member    @relation("Partner1", fields: [partner1Id], references: [id])
  partner2    Member    @relation("Partner2", fields: [partner2Id], references: [id])

  @@unique([partner1Id, partner2Id])
}
